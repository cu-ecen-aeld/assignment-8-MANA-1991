#!/bin/sh

case "$1" in
    start)
        echo "Loading aesdchar module..."
        modprobe aesdchar || exit 1

        major=$(awk '$2=="aesdchar" {print $1}' /proc/devices)
        if [ -z "$major" ]; then
            echo "aesdchar: failed to find major number"
            exit 1
        fi

        rm -f /dev/aesdchar
        mknod /dev/aesdchar c "$major" 0
        chmod 666 /dev/aesdchar

        echo "aesdchar loaded (major=$major)"
        ;;
    stop)
        echo "Unloading aesdchar..."
        rm -f /dev/aesdchar
        rmmod aesdchar
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac
exit 0